<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cat Voter Pro</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 font-sans">

    <div class="container mx-auto px-4 py-8">
        <header class="text-center mb-12">
            <h1 class="text-4xl font-bold text-gray-800">Cat Voter 🐾</h1>
            <p class="text-gray-600">Upvote your favorite feline friends!</p>
        </header>

        <% if (error) { %>
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4">
                <%= error %>
            </div>
        <% } %>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <% cats.forEach(cat => { %>
                <div class="bg-white rounded-lg shadow-md overflow-hidden">
                    <img src="<%= cat.url %>" alt="A cute cat" class="w-full h-64 object-cover">
                    <div class="p-4 flex justify-between items-center">
                        <span class="text-sm font-medium text-gray-500">ID: <%= cat.id %></span>
                        
                        <!-- POST REQUEST FORM -->
                        <form action="/vote" method="POST" class="inline">
                            <input type="hidden" name="image_id" value="<%= cat.id %>">
                            <input type="hidden" name="sub_id" value="user-123">
                            <input type="hidden" name="value" value="1"> <!-- 1 = Upvote -->
                            <button type="submit" class="bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-full transition">
                                ❤️ Love it!
                            </button>
                        </form>
                    </div>
                </div>
            <% }); %>
        </div>

        <div class="text-center mt-12">
            <a href="/" class="bg-gray-800 text-white px-8 py-3 rounded-lg hover:bg-gray-700">Refresh New Cats</a>
        </div>
    </div>

</body>
</html>